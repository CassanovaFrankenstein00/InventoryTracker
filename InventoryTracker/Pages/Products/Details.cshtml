@page
@model InventoryTracker.Pages.Products.DetailsModel

@{
    ViewData["Title"] = "Details";
}
<div class="text-center bg-dark rounded-1 bg-opacity-75">
<h1>Details</h1>

<div>
    <h4>Product</h4>
    <hr />
    <dl class="row text-white">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Product.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Product.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Product.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Product.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Product.Qty)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Product.Qty)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Product.Make)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Product.Make)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Product.Category)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Product.Category.Id)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Product.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
</div>